# Copy this file to .env and fill in your own values.
# Never commit real secrets.

# Qwen / DashScope compatible-mode key
QWEN_API_KEY=

# Optional service endpoints
GRADIO_SERVER_IP=127.0.0.1
GRADIO_SERVER_PORT=7000
CAPTURE_SERVER_IP=0.0.0.0
CAPTURE_SERVER_PORT=3000
SAM_SERVER_IP=127.0.0.1
SAM_SERVER_PORT=7002

# Optional external control APIs (example placeholders)
API_URL_CTRL = "http://<IPv4 of MSFS2024 Computer>:5000/set"
API_URL_CAMERA = "http://<IPv4 of MSFS2024 Computer>:5000/camera_image"
API_URL_GET = "http://<IPv4 of MSFS2024 Computer>:5000/get"
API_URL_CAMERA_CTRL = "http://<IPv4 of MSFS2024 Computer>:5000/camera_control"
